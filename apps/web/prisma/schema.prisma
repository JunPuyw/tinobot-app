// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  persona   String?
  googleId  String?  @unique
  role      String   @default("user")
  isBanned  Boolean  @default(false)
  credits   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  apiKeys     ApiKey[]
  connections ProviderConnection[]
  combos      ModelCombo[]
  platformUsages PlatformUsage[]
}

model ClientDailyUsage {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  logDate    String   @map("log_date")
  tokensUsed Int      @default(0) @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([clientId, logDate])
  @@map("client_daily_usage")
}

model GatewaySetting {
  id                    String   @id @default("default")
  platformMarkupPercent Float    @default(0)
  vndUsdRate            Float    @default(25000)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PlatformUsage {
  id             String   @id @default(cuid())
  userId         String
  model          String
  pricingMode    String
  promptTokens   Int      @default(0)
  completionTokens Int    @default(0)
  baseCredits    Float
  markupPercent  Float
  chargedCredits Float
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PricingPackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceUSD    Float
  credits     Float
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  prefix    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model ProviderConnection {
  id           String   @id @default(cuid())
  provider     String
  name         String?
  apiKey       String?
  authType     String   @default("apikey")
  priority     Int      @default(1)
  isActive     Boolean  @default(true)
  testStatus   String   @default("unknown")
  lastError    String?
  lastErrorAt  DateTime?
  errorCode    String?
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  
  proxyPoolId  String?
}

model ModelCombo {
  id        String   @id @default(cuid())
  name      String
  models    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([userId, name])
}

model ProviderNode {
  id        String   @id @default(cuid())
  name      String?
  type      String   // "openai-compatible", "anthropic-compatible"
  apiType   String?
  baseUrl   String?
  createdAt DateTime @default(now())
}

model RouterLog {
  id             String   @id @default(cuid())
  requestedModel String
  usedModel      String?
  success        Boolean
  rotated        Boolean  @default(false)
  totalAttempts  Int
  attempts       String   // JSON string of attempts
  timestamp      DateTime @default(now())
}
