{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "env": [
        "SEPAY_ACCOUNT_NAME",
        "SEPAY_WEBHOOK_KEY",
        "VND_TO_USD_RATE",
        "SEPAY_ACCOUNT_NO",
        "SEPAY_BANK_ID",
        "SEPAY_QR_TEMPLATE",
        "SEPAY_API_TOKEN",
        "SEPAY_VA_BANK_ACCOUNT_ID",
        "SEPAY_VA_PROVIDER_PATH",
        "SEPAY_API_BASE_URL"
      ],
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
