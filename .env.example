PORT=3001
WEB_PORT=3000
API_PORT=3001
NODE_ENV=development

POSTGRES_DB=tinobot
POSTGRES_USER=tinobot
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://tinobot:change-this-password@localhost:5432/tinobot?schema=public
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_EMAILS=admin@example.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Preferred scalable platform configuration. Add more endpoints or keys as needed.
PLATFORM_UPSTREAMS_JSON=[{"name":"primary","baseUrl":"https://platform.example.com/api/v1","apiKeys":["replace-with-platform-key"]}]

# Legacy single-endpoint configuration remains supported.
# PLATFORM_API_BASE_URL=https://platform.example.com/api/v1
# PLATFORM_API_KEYS=replace-with-key-1,replace-with-key-2
# BEEKNOEE_API_BASE=https://platform.beeknoee.com/api/v1
# BEEKNOEE_KEYS=replace-with-key-1,replace-with-key-2
# BEEKNOEE_KEY=replace-with-single-key

# Optional SePay billing
SEPAY_BANK_ID=VCB
SEPAY_ACCOUNT_NO=replace-with-bank-account-number
SEPAY_ACCOUNT_NAME=REPLACE WITH ACCOUNT NAME
SEPAY_WEBHOOK_KEY=replace-with-long-random-webhook-key
VND_TO_USD_RATE=25000

# Optional Polar billing
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
