POSTGRES_DB=tinobot
POSTGRES_USER=tinobot
POSTGRES_PASSWORD=change-this-password

DATABASE_URL=postgresql://tinobot:change-this-password@postgres:5432/tinobot?schema=public
NODE_ENV=production
PORT=3001
WEB_PORT=3000
API_PORT=3001

NEXT_PUBLIC_APP_URL=https://your-domain.com
INTERNAL_API_URL=http://api:3001
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com

PLATFORM_UPSTREAMS_JSON=[{"name":"primary","baseUrl":"https://platform.example.com/api/v1","apiKeys":["replace-with-platform-key"]}]

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional billing
SEPAY_ACCOUNT_NAME=
SEPAY_WEBHOOK_KEY=
SEPAY_ACCOUNT_NO=
SEPAY_BANK_ID=
VND_TO_USD_RATE=25000
